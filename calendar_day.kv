#:kivy 2.3.0
#:import dp kivy.metrics.dp


<CalendarDayTeamBox@BoxLayout>:
    logo_source: ""
    abbrev: ""
    team_name: ""
    team_color: 0.95, 0.98, 1, 1
    orientation: "horizontal"
    size_hint_y: None
    height: dp(72)
    spacing: dp(10)

    AnchorLayout:
        size_hint_x: None
        width: dp(64)
        anchor_x: "center"
        anchor_y: "center"

        AsyncImage:
            source: root.logo_source
            fit_mode: "contain"
            size_hint: None, None
            size: dp(52), dp(52)

    BoxLayout:
        orientation: "vertical"
        spacing: dp(2)
        padding: 0, dp(7), 0, dp(7)

        Label:
            text: root.abbrev
            color: root.team_color
            bold: True
            font_size: "16sp"
            size_hint_y: None
            height: dp(26)
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.team_name
            color: 0.72, 0.78, 0.88, 1
            font_size: "11sp"
            size_hint_y: None
            height: dp(22)
            shorten: True
            shorten_from: "right"
            halign: "left"
            valign: "middle"
            text_size: self.size


<CalendarDayEventCard>:
    orientation: "vertical"
    size_hint_y: None
    height: dp(224)
    padding: dp(12)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: 0.03, 0.06, 0.10, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
        Color:
            rgba: root.sport_color
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(12)
            width: 1.3

    BoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: dp(30)
        spacing: dp(7)

        Label:
            text: root.sport_label
            color: root.sport_color
            bold: True
            font_size: "11sp"
            size_hint_x: None
            width: dp(42)
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.title
            color: 0.96, 0.98, 1, 1
            bold: True
            font_size: "15sp"
            shorten: True
            shorten_from: "right"
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.time_text
            color: 0.72, 0.92, 1, 1
            bold: True
            font_size: "11sp"
            size_hint_x: None
            width: dp(88)
            halign: "right"
            valign: "middle"
            text_size: self.size

    BoxLayout:
        opacity: 0 if root.is_f1 else 1
        height: 0 if root.is_f1 else dp(72)
        size_hint_y: None
        spacing: dp(10)

        CalendarDayTeamBox:
            logo_source: root.away_logo
            abbrev: root.away_abbreviation
            team_name: root.away_name
            team_color: root.away_color

        Label:
            text: "@"
            color: 0.50, 0.62, 0.78, 1
            bold: True
            font_size: "14sp"
            size_hint_x: None
            width: dp(32)
            halign: "center"
            valign: "middle"
            text_size: self.size

        CalendarDayTeamBox:
            logo_source: root.home_logo
            abbrev: root.home_abbreviation
            team_name: root.home_name
            team_color: root.home_color

    BoxLayout:
        opacity: 1 if root.is_f1 else 0
        height: dp(72) if root.is_f1 else 0
        size_hint_y: None
        spacing: dp(8)

        Label:
            text: root.session_text
            color: 0.98, 0.99, 1, 1
            bold: True
            font_size: "16sp"
            size_hint_x: 0.42
            shorten: True
            shorten_from: "right"
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.broadcast_text
            color: 0.76, 0.83, 0.92, 1
            font_size: "10sp"
            shorten: True
            shorten_from: "right"
            halign: "right"
            valign: "middle"
            text_size: self.size

    BoxLayout:
        orientation: "vertical"
        size_hint_y: None
        height: dp(64)
        spacing: dp(3)

        Label:
            text: root.status_text
            color: 0.50, 0.62, 0.78, 1
            font_size: "11sp"
            size_hint_y: None
            height: dp(18)
            shorten: True
            shorten_from: "right"
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.venue_text
            color: 0.78, 0.86, 0.96, 1
            font_size: "11sp"
            size_hint_y: None
            height: dp(18)
            shorten: True
            shorten_from: "right"
            halign: "left"
            valign: "middle"
            text_size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(18)
            spacing: dp(4)

            LoadingSpinner:
                active: root.weather_text.startswith("Loading")
                size_hint_x: None
                width: dp(18) if self.active else 0

            Label:
                text: root.weather_text
                color: 0.72, 0.82, 0.94, 1
                font_size: "11sp"
                shorten: True
                shorten_from: "right"
                halign: "left"
                valign: "middle"
                text_size: self.size


<CalendarDayPopup>:
    title: ""
    size_hint: 0.82, 0.84
    auto_dismiss: True
    background_color: 0.015, 0.025, 0.045, 1

    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(8)
        canvas.before:
            Color:
                rgba: 0.015, 0.025, 0.045, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            BoxLayout:
                orientation: "vertical"
                spacing: 0

                Label:
                    text: root.title_text
                    color: 0.96, 0.98, 1, 1
                    bold: True
                    font_size: "18sp"
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

                Label:
                    text: root.subtitle_text
                    color: 0.50, 0.62, 0.78, 1
                    font_size: "11sp"
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

            Button:
                text: "Close"
                size_hint_x: None
                width: dp(78)
                on_release: root.dismiss()

        ScrollView:
            do_scroll_x: False
            bar_width: dp(6)

            GridLayout:
                id: events_body
                cols: 1
                spacing: dp(6)
                size_hint_y: None
                height: self.minimum_height
